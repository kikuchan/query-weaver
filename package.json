{
  "name": "query-weaver",
  "version": "0.2.0-alpha.3",
  "description": "SQL query builder using template string literal",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist/"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "vitest run && tsc --noEmit",
    "test:watch": "vitest",
    "build": "tsdown",
    "prepack": "pnpm run build && pnpm run test",
    "format": "prettier",
    "lint": "eslint --fix",
    "type:check": "tsc --noEmit",
    "prepare": "husky"
  },
  "author": "kikuchan98@gmail.com",
  "homepage": "https://github.com/kikuchan/query-weaver#readme",
  "license": "MIT",
  "devDependencies": {
    "@eslint/compat": "^1.3.2",
    "@eslint/js": "^9.35.0",
    "@kikuchan/string-reader": "0.1.0-alpha.3",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "esbuild": "^0.25.1",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "pg": "^8.14.1",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.2.0",
    "rimraf": "^6.0.1",
    "tsdown": "^0.15.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.43.0",
    "vitest": "^3.0.9"
  },
  "packageManager": "pnpm@10.6.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ]
  }
}
