{
  "name": "query-weaver",
  "version": "0.2.0-alpha.4",
  "description": "SQL query builder using template string literal",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist/"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "vitest run && tsc --noEmit",
    "test:watch": "vitest",
    "build": "tsdown",
    "prepack": "pnpm run build && pnpm run test",
    "format": "prettier",
    "lint": "eslint --fix",
    "type:check": "tsc --noEmit",
    "prepare": "husky"
  },
  "author": "kikuchan98@gmail.com",
  "homepage": "https://github.com/kikuchan/query-weaver#readme",
  "repository": {
    "url": "https://github.com/kikuchan/query-weaver"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@kikuchan/string-reader": "0.1.0-alpha.7",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "pg": "^8.19.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "rimraf": "^6.1.3",
    "tsdown": "0.21.0-beta.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ]
  }
}
