{
  "name": "query-weaver",
  "version": "0.2.0-alpha.5",
  "description": "SQL query builder using template string literal",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist/"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "vitest run && tsc --noEmit",
    "test:watch": "vitest",
    "build": "tsdown",
    "prepack": "pnpm run build && pnpm run test",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "type:check": "tsc --noEmit",
    "prepare": "husky"
  },
  "author": "kikuchan98@gmail.com",
  "homepage": "https://github.com/kikuchan/query-weaver#readme",
  "repository": {
    "url": "https://github.com/kikuchan/query-weaver"
  },
  "license": "MIT",
  "devDependencies": {
    "@kikuchan/string-reader": "0.1.0-alpha.8",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "esbuild": "^0.27.4",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "pg": "^8.20.0",
    "prettier-plugin-organize-imports": "^4.3.0",
    "rimraf": "^6.1.3",
    "tsdown": "0.21.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ]
  }
}
