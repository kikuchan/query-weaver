{
  "name": "query-weaver",
  "version": "0.2.0-alpha.3",
  "description": "SQL query builder using template string literal",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.mjs",
      "require": "./dist/index.cjs.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "pnpm run clean && pnpm run build:esm && pnpm run build:cjs && pnpm run build:types",
    "build:esm": "esbuild --bundle src/index.ts --format=esm --outfile=dist/index.esm.mjs --minify --sourcemap",
    "build:cjs": "esbuild --bundle src/index.ts --format=cjs --outfile=dist/index.cjs.js  --minify --sourcemap",
    "build:types": "tsc --declaration --emitDeclarationOnly --declarationDir './dist'",
    "prepack": "pnpm run build && pnpm run test",
    "format": "biome format ./src",
    "format:fix": "biome format ./src --write",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint ./src --write",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "prepare": "husky"
  },
  "author": "kikuchan98@gmail.com",
  "homepage": "https://github.com/kikuchan/query-weaver#readme",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@kikuchan/string-reader": "0.1.0-alpha.3",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "esbuild": "^0.25.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "pg": "^8.14.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "packageManager": "pnpm@10.6.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ]
  }
}
