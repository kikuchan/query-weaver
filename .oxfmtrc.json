{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "tabWidth": 2,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "bracketSpacing": true,
  "bracketSameLine": true,
  "arrowParens": "always",
  "organizeImportsSkipDestructiveCodeActions": true,
  "sortPackageJson": false,
  "ignorePatterns": [
    "/dist",
    "/files",
    "/node_modules",
    "/playground",
    "/.vite",
    "/.local",
    "*.md",
    "/*.json",
    "/*.yaml"
  ]
}
